# 小洛克电竞 Customer MVP production environment example
# Copy this file to .env.local for local development, or configure these keys in Vercel / server environment variables.

# App
NEXT_PUBLIC_APP_NAME=小洛克电竞
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_SITE_URL=https://example.com
PORT=3000

# Deployment
# Use a git commit SHA, timestamp, or release version.
# Next.js can use this to reduce version-skew issues during self-hosted deployments.
DEPLOYMENT_VERSION=local-dev

# Data source
# Current MVP uses localStorage mock data.
# Later switch DATA_SOURCE to mongodb and implement server APIs.
DATA_SOURCE=mock
MONGODB_URI=
MONGODB_DB=xiaoluoke_esports

# WeChat Official Account OAuth placeholder, not Mini Program wx.login.
WECHAT_OFFICIAL_APP_ID=
WECHAT_OFFICIAL_APP_SECRET=
WECHAT_OAUTH_REDIRECT_URI=https://example.com/api/auth/wechat/callback

# Payment placeholders. Do not enable real payments until backend order validation is ready.
WECHAT_PAY_ENABLED=false
ALIPAY_ENABLED=false
LOCKE_COIN_PAY_ENABLED=true
